# Copy to deploy/production/.env on the VPS. Do not commit real .env files.

DATABASE_URL=postgres://achievno:change-me@127.0.0.1:5432/achievno
DJANGO_SECRET_KEY=change-me
ACCESS_TOKEN_SECRET=change-me

DJANGO_ALLOWED_HOSTS=api.achievno.dkar-dev.ru,localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=https://achievno.dkar-dev.ru
ACHIEVNO_PUBLIC_APP_URL=https://achievno.dkar-dev.ru
ACHIEVNO_AUTH_COOKIE_SECURE=true
ACHIEVNO_AUTH_COOKIE_SAMESITE=None

EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=true
DEFAULT_FROM_EMAIL=

API_HOST_BIND=127.0.0.1
API_HOST_PORT=8000

EVIDENCE_STORAGE_BACKEND=local
EVIDENCE_STORAGE_LOCAL_ROOT=/app/var/evidence
CLOUDFLARE_R2_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET=achievno-evidence-dev
CLOUDFLARE_R2_ENDPOINT_URL=https://<account-id>.r2.cloudflarestorage.com
