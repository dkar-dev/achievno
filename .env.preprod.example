# Copy this file locally and export the values before running scripts/preprod/*.sh.
# Do not commit real secrets or live database credentials.

# Containers usually need host.containers.internal when the existing PostgreSQL
# container publishes its port on the host.
PREPROD_DATABASE_URL=postgres://postgres:change-me@host.containers.internal:5432/softos

# If your existing PostgreSQL container is reachable only on a named Podman
# network, set that existing network and use the DB container hostname in
# PREPROD_DATABASE_URL. The runtime does not create or modify this network.
# PREPROD_PODMAN_NETWORK=softos-dev

DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,achievno-preprod-api,testserver
CORS_ALLOWED_ORIGINS=http://127.0.0.1:3000,http://localhost:3000
DJANGO_SECRET_KEY=change-me-local-preprod
ACCESS_TOKEN_SECRET=change-me-local-preprod-access

NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000
NEXT_PUBLIC_USE_MOCKS=false
